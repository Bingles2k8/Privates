{
  "expo": {
    "name": "Privates",
    "slug": "PrivatesTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "privatestracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.privatestracker",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "NSFaceIDUsageDescription": "Used to unlock your private health data on this device. Your data never leaves the device unless you explicitly export it.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.privatestracker",
      "allowBackup": false,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.1"
          },
          "android": {
            "usesCleartextTraffic": false,
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Used to unlock your private health data on this device."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#000000"
        }
      ],
      [
        "expo-dynamic-app-icon",
        {
          "mascot-bright": {
            "image": "./assets/icons/mascot-bright.png",
            "prerendered": true
          },
          "mascot-wink": {
            "image": "./assets/icons/mascot-wink.png",
            "prerendered": true
          },
          "mascot-sleepy": {
            "image": "./assets/icons/mascot-sleepy.png",
            "prerendered": true
          },
          "calculator": {
            "image": "./assets/icons/calculator.png",
            "prerendered": true
          },
          "weather": {
            "image": "./assets/icons/weather.png",
            "prerendered": true
          },
          "notes": {
            "image": "./assets/icons/notes.png",
            "prerendered": true
          },
          "paper": {
            "image": "./assets/icons/paper.png",
            "prerendered": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
